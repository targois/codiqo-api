generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProgrammingLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  HTML_CSS
  REACT
}

enum UserLearningLevel {
  BEGINNER
  BASIC
  INTERMEDIATE
}

enum LearningGoal {
  CAREER
  STUDY
  PET_PROJECT
  JUST_FOR_FUN
}

enum DailyLearningTime {
  FIVE_MIN
  TEN_MIN
  FIFTEEN_MIN
  THIRTY_MIN
}

enum PreferredLearningFormat {
  THEORY_FIRST
  PRACTICE_FIRST
  MIXED
}

enum LessonDifficulty {
  BEGINNER
  BASIC
  INTERMEDIATE
}

enum LessonContentType {
  TEXT
}

enum QuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  FILL_CODE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique
  passwordHash         String
  displayName          String?
  avatarUrl            String?
  xp                   Int       @default(0)
  level                Int       @default(1)
  streak               Int       @default(0)
  lastActivityDate     DateTime?
  isOnboardingComplete Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  onboarding           Onboarding?
  progress             UserLessonProgress[]
  dailyActivities      DailyActivity[]

  @@map("users")
}

model Onboarding {
  id               String                  @id @default(uuid())
  userId           String                  @unique
  selectedLanguage ProgrammingLanguage
  currentLevel     UserLearningLevel
  learningGoal     LearningGoal
  dailyTime        DailyLearningTime
  preferredFormat  PreferredLearningFormat
  isCompleted      Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboardings")
}

model Lesson {
  id               String              @id @default(uuid())
  title            String
  description      String
  language         ProgrammingLanguage
  difficulty       LessonDifficulty
  estimatedMinutes Int
  xpReward         Int                 @default(10)
  order            Int
  isPublished      Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  theoryBlocks     TheoryBlock[]
  quizQuestions    QuizQuestion[]
  codeTasks        CodeTask[]
  userProgress     UserLessonProgress[]

  @@map("lessons")
}

model TheoryBlock {
  id        String            @id @default(uuid())
  lessonId  String
  lesson    Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type      LessonContentType
  content   String
  order     Int
  createdAt DateTime          @default(now())

  @@map("theory_blocks")
}

model QuizQuestion {
  id        String           @id @default(uuid())
  lessonId  String
  lesson    Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question  String
  type      QuizQuestionType
  order     Int
  createdAt DateTime         @default(now())

  answers   QuizAnswer[]

  @@map("quiz_questions")
}

model QuizAnswer {
  id         String       @id @default(uuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean
  createdAt  DateTime     @default(now())

  @@map("quiz_answers")
}

model CodeTask {
  id             String   @id @default(uuid())
  lessonId       String
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  starterCode    String
  expectedAnswer String
  order          Int
  createdAt      DateTime @default(now())

  @@map("code_tasks")
}

model UserLessonProgress {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progressPercent Int       @default(0)
  isCompleted     Boolean   @default(false)
  xpEarned        Int       @default(0)
  completedAt     DateTime?
  lastOpenedAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model DailyActivity {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  lessonsCompleted Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_activities")
}
