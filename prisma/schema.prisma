generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProgrammingLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  HTML_CSS
  REACT
}

enum UserLearningLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LearningGoal {
  CAREER
  STUDY
  PET_PROJECT
  JUST_FOR_FUN
}

enum DailyLearningTime {
  FIVE_MIN
  TEN_MIN
  FIFTEEN_MIN
  THIRTY_MIN
}

enum PreferredLearningFormat {
  THEORY_FIRST
  PRACTICE_FIRST
  MIXED
}

enum ChallengeValidationType {
  EXACT_MATCH
  NORMALIZED_MATCH
}

enum SkillTag {
  VARIABLES
  LOOPS
  FUNCTIONS
  RECURSION
  OOP
  CONDITIONS
  LISTS
  DICTIONARIES
  STRINGS
  ARRAYS
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique
  passwordHash         String
  displayName          String?
  avatarUrl            String?
  xp                   Int       @default(0)
  level                Int       @default(1)
  streak               Int       @default(0)
  lastActivityDate     DateTime?
  isOnboardingComplete Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  onboarding      Onboarding?
  progress        UserLessonProgress[]
  dailyActivities DailyActivity[]
  xpTransactions  XPTransaction[]
  dailyChallenges UserDailyChallenge[]
  skillMasteries  UserSkillMastery[]
  skillReviews    UserSkillReview[]
  badges          UserBadge[]
  sentFriendRequests     Friendship[] @relation("FriendRequester")
  receivedFriendRequests Friendship[] @relation("FriendAddressee")
  collabParticipations   CollaborativeChallengeParticipant[]

  @@map("users")
}

model Onboarding {
  id               String                  @id @default(uuid())
  userId           String                  @unique
  selectedLanguage ProgrammingLanguage
  currentLevel     UserLearningLevel
  learningGoal     LearningGoal
  dailyTime        DailyLearningTime
  preferredFormat  PreferredLearningFormat
  startingLessonId String?
  isCompleted      Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboardings")
}

// ─── Progression engine ──────────────────────────────────────────────────────

model UserLessonProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  xpEarned    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model DailyActivity {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  lessonsCompleted Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_activities")
}

model XPTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  lessonId  String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("xp_transactions")
}

// ─── Daily challenge ─────────────────────────────────────────────────────────

model DailyChallenge {
  id               String                  @id @default(uuid())
  slug             String                  @unique
  title            String
  description      String
  difficulty       String
  estimatedMinutes Int
  xpReward         Int                     @default(25)
  language         String
  starterCode      String
  expectedOutput   String
  hint             String?
  validationType   ChallengeValidationType
  expectedSolution String?
  createdAt        DateTime                @default(now())

  userChallenges UserDailyChallenge[]

  @@map("daily_challenges")
}

model UserDailyChallenge {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId   String
  challenge     DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  submittedCode String?
  isCompleted   Boolean        @default(false)
  completedAt   DateTime?
  createdAt     DateTime       @default(now())

  @@unique([userId, challengeId])
  @@map("user_daily_challenges")
}

// ─── Adaptive learning ───────────────────────────────────────────────────────
//
// UserSkillMastery — Bayesian Knowledge Tracing state per skill.
// UserSkillReview  — SM-2 spaced-repetition schedule per skill.

model UserSkillMastery {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillTag         SkillTag
  masteryScore     Float    @default(0)
  correctAnswers   Int      @default(0)
  incorrectAnswers Int      @default(0)
  totalAttempts    Int      @default(0)
  confidenceLevel  Float    @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([userId, skillTag])
  @@map("user_skill_mastery")
}

model UserSkillReview {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillTag        SkillTag
  intervalDays    Float     @default(1)
  easeFactor      Float     @default(2.5)
  repetitionCount Int       @default(0)
  nextReviewAt    DateTime
  lastReviewedAt  DateTime?
  createdAt       DateTime  @default(now())

  @@unique([userId, skillTag])
  @@index([userId, nextReviewAt])
  @@map("user_skill_reviews")
}

// ─── Badges ──────────────────────────────────────────────────────────────────

model Badge {
  id            String    @id @default(uuid())
  slug          String    @unique
  title         String
  description   String
  iconKey       String
  skillTag      SkillTag?
  xpRequirement Int?
  createdAt     DateTime  @default(now())

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId    String
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())
  isSeen     Boolean  @default(false)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

// ─── Social ──────────────────────────────────────────────────────────────────

model Friendship {
  id          String           @id @default(uuid())
  requesterId String
  requester   User             @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User             @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus
  createdAt   DateTime         @default(now())

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@map("friendships")
}

model CollaborativeChallenge {
  id        String   @id @default(uuid())
  title     String
  xpGoal    Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  participants CollaborativeChallengeParticipant[]

  @@map("collaborative_challenges")
}

model CollaborativeChallengeParticipant {
  id            String                 @id @default(uuid())
  challengeId   String
  challenge     CollaborativeChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId        String
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributedXp Int                    @default(0)

  @@unique([challengeId, userId])
  @@map("collaborative_challenge_participants")
}
