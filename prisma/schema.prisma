generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ProgrammingLanguage {
  JAVASCRIPT
  TYPESCRIPT
  PYTHON
  HTML_CSS
  REACT
}

enum UserLearningLevel {
  BEGINNER
  BASIC
  INTERMEDIATE
}

enum LearningGoal {
  CAREER
  STUDY
  PET_PROJECT
  JUST_FOR_FUN
}

enum DailyLearningTime {
  FIVE_MIN
  TEN_MIN
  FIFTEEN_MIN
  THIRTY_MIN
}

enum PreferredLearningFormat {
  THEORY_FIRST
  PRACTICE_FIRST
  MIXED
}

enum LessonDifficulty {
  BEGINNER
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum LessonBlockType {
  THEORY
  ANALOGY
  CODE
  EXPLANATION
  MISTAKE
  QUIZ
}

enum LessonProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  username             String    @unique
  passwordHash         String
  displayName          String?
  avatarUrl            String?
  xp                   Int       @default(0)
  level                Int       @default(1)
  streak               Int       @default(0)
  lastActivityDate     DateTime?
  isOnboardingComplete Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  onboarding         Onboarding?
  progress           UserLessonProgress[]
  blockProgress      UserLessonBlockProgress[]
  dailyActivities    DailyActivity[]
  xpTransactions     XPTransaction[]
  dailyChallenges    UserDailyChallenge[]

  @@map("users")
}

model Onboarding {
  id               String                  @id @default(uuid())
  userId           String                  @unique
  selectedLanguage ProgrammingLanguage
  currentLevel     UserLearningLevel
  learningGoal     LearningGoal
  dailyTime        DailyLearningTime
  preferredFormat  PreferredLearningFormat
  isCompleted      Boolean                 @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboardings")
}

// ─── Course → Section → Lesson → Block hierarchy ─────────────────────────────

model Course {
  id               String              @id @default(uuid())
  slug             String              @unique
  title            String
  description      String
  language         ProgrammingLanguage
  difficulty       LessonDifficulty
  estimatedMinutes Int
  totalXp          Int
  isPublished      Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  sections         CourseSection[]

  @@map("courses")
}

model CourseSection {
  id               String   @id @default(uuid())
  courseId         String
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  order            Int
  estimatedMinutes Int
  totalXp          Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lessons          Lesson[]

  @@map("course_sections")
}

model Lesson {
  id               String           @id @default(uuid())
  slug             String           @unique
  sectionId        String
  section          CourseSection    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title            String
  description      String
  order            Int
  estimatedMinutes Int
  xpReward         Int              @default(10)
  difficulty       LessonDifficulty
  isPublished      Boolean          @default(false)
  isFree           Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  blocks         LessonBlock[]
  progress       UserLessonProgress[]
  xpTransactions XPTransaction[]

  @@map("lessons")
}

model LessonBlock {
  id        String          @id @default(uuid())
  lessonId  String
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type      LessonBlockType
  order     Int
  payload   Json
  createdAt DateTime        @default(now())

  userProgress UserLessonBlockProgress[]

  @@map("lesson_blocks")
}

// ─── User progress ───────────────────────────────────────────────────────────

model UserLessonProgress {
  id              String               @id @default(uuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status          LessonProgressStatus @default(NOT_STARTED)
  progressPercent Int                  @default(0)
  isCompleted     Boolean              @default(false)
  xpEarned        Int                  @default(0)
  completedAt     DateTime?
  lastOpenedAt    DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([userId, lessonId])
  @@map("user_lesson_progress")
}

model UserLessonBlockProgress {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockId     String
  block       LessonBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  isCompleted Boolean     @default(false)
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  @@unique([userId, blockId])
  @@map("user_lesson_block_progress")
}

model DailyActivity {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  lessonsCompleted Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_activities")
}

// ─── XP economy ──────────────────────────────────────────────────────────────

model XPTransaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  lessonId  String?
  lesson    Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@map("xp_transactions")
}

// ─── Daily challenges (architecture only, no endpoints yet) ──────────────────

model DailyChallenge {
  id          String              @id @default(uuid())
  title       String
  description String
  language    ProgrammingLanguage
  xpReward    Int
  isPublished Boolean             @default(false)
  createdAt   DateTime            @default(now())

  userChallenges UserDailyChallenge[]

  @@map("daily_challenges")
}

model UserDailyChallenge {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  isCompleted Boolean        @default(false)
  completedAt DateTime?

  @@unique([userId, challengeId])
  @@map("user_daily_challenges")
}
